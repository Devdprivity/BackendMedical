# Puerto del servicio
PORT=3000

# URL del backend Laravel
LARAVEL_API_URL=http://localhost:8000

# Token de autenticación para comunicarse con Laravel
# Este token debe coincidir con el que Laravel usará para autenticar las peticiones
LARAVEL_API_TOKEN=your-secret-token-here

# Configuración de rate limiting (mensajes por período)
RATE_LIMIT_PER_MINUTE=3
RATE_LIMIT_PER_HOUR=15
RATE_LIMIT_PER_DAY=100

# Delays entre mensajes (en milisegundos)
DELAY_BETWEEN_MESSAGES=3000
RANDOM_DELAY_RANGE=2000
